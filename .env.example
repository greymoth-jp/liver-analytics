# Database (Turso)
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-token

# Better Auth
BETTER_AUTH_SECRET=your-secret-32-chars-min
BETTER_AUTH_URL=http://localhost:3040

# Email (Resend)
RESEND_API_KEY=re_your_key

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret
STRIPE_PRICE_ID_MONTHLY=price_your_monthly
STRIPE_PRICE_ID_ANNUAL=price_your_annual

# Analytics / Monitoring
POSTHOG_KEY=phc_your_key
SENTRY_DSN=https://your@sentry.io/project

# AI (Anthropic Claude Haiku)
ANTHROPIC_API_KEY=sk-ant-your_key

# Auth providers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Apple (optional, requires HTTPS + registered domain)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
